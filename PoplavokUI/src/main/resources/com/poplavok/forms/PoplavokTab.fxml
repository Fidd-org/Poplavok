                                    </TableColumn>
                                    <TableColumn text="Destination">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="DestinationName" />
                                       </cellValueFactory>
                                    </TableColumn>
                                 </columns>
                              </TableView>
                           </children>
                        </AnchorPane>
                  </content>
                </Tab>
                <Tab text="Trades (level)">
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <TableView fx:id="tradesTable" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                 <columns>
                                    <TableColumn text="TransactionId">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="Id" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="TransactionType">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="TransactionType" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Amount">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="Amount" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Date">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="Date" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Currency">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="CurrencyCode" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Source">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="SourceName" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Destination">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="DestinationName" />
                                       </cellValueFactory>
                                    </TableColumn>
                                 </columns>
                              </TableView>
                           </children>
                        </AnchorPane>
                  </content>
                </Tab>
                  <Tab text="Level Strategy">
                     <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <SplitPane dividerPositions="0.0" orientation="VERTICAL" prefHeight="200.0" prefWidth="160.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                 <items>
                                    <AnchorPane maxHeight="40.0" minHeight="40.0" minWidth="0.0" prefHeight="40.0" prefWidth="160.0">
                                       <children>
                                          <ToolBar prefHeight="40.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                             <items>
                                                <Label text="Strategy:" />
                                                <ComboBox prefWidth="150.0" />
                                                <Label text="Enty point:" />
                                                <TextField maxWidth="50.0" minWidth="50.0" prefWidth="50.0" />
                                                <Button mnemonicParsing="false" text="[ Add Level ]" />
                                             </items>
                                          </ToolBar>
                                       </children>
                                    </AnchorPane>
                                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="100.0" prefWidth="160.0">
                                       <children>
                                          <TableView fx:id="transactionsTable2" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                             <columns>
                                                <TableColumn text="TransactionId">
                                                   <cellValueFactory>
                                                      <PropertyValueFactory property="Id" />
                                                   </cellValueFactory>
                                                </TableColumn>
                                                <TableColumn text="TransactionType">
                                                   <cellValueFactory>
                                                      <PropertyValueFactory property="TransactionType" />
                                                   </cellValueFactory>
                                                </TableColumn>
                                                <TableColumn text="Amount">
                                                   <cellValueFactory>
                                                      <PropertyValueFactory property="Amount" />
                                                   </cellValueFactory>
                                                </TableColumn>
                                                <TableColumn text="Date">
                                                   <cellValueFactory>
                                                      <PropertyValueFactory property="Date" />
                                                   </cellValueFactory>
                                                </TableColumn>
                                                <TableColumn text="Currency">
                                                   <cellValueFactory>
                                                      <PropertyValueFactory property="CurrencyCode" />
                                                   </cellValueFactory>
                                                </TableColumn>
                                                <TableColumn text="Source">
                                                   <cellValueFactory>
                                                      <PropertyValueFactory property="SourceName" />
                                                   </cellValueFactory>
                                                </TableColumn>
                                                <TableColumn text="Destination">
                                                   <cellValueFactory>
                                                      <PropertyValueFactory property="DestinationName" />
                                                   </cellValueFactory>
                                                </TableColumn>
                                             </columns>
                                          </TableView>
                                       </children>
                                    </AnchorPane>
                                 </items>
                              </SplitPane>
                           </children>
                        </AnchorPane>
                     </content>
                  </Tab>
              </tabs>
            </TabPane>
         </children>
      </AnchorPane>
    </SplitPane>
</fx:root>
