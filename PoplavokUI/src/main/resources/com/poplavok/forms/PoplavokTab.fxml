                                        <PropertyValueFactory property="availableAmountQuote" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="DebtBase">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="debtBase" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="DebtQuote">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="debtQuote" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="LentAmountBase">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="lentAmountBase" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="LentAmountQuote">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="lentAmountQuote" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="IsActive">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="isActive" />
                                    </cellValueFactory>
                                </TableColumn>
                                <TableColumn text="CloseDate">
                                    <cellValueFactory>
                                        <PropertyValueFactory property="closeDate" />
                                    </cellValueFactory>
                                </TableColumn>
                            </columns>
                        </TableView>
                  </children>
               </AnchorPane>
             <AnchorPane maxWidth="250.0" minWidth="250.0" prefWidth="250.0" SplitPane.resizableWithParent="false">
                  <children>
                     <VBox layoutX="48.0" layoutY="47.0" maxWidth="250.0" minWidth="250.0" prefHeight="200.0" prefWidth="250.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                  </children></AnchorPane>
           </items>
         </SplitPane>
        </AnchorPane>
      <AnchorPane>
         <children>
            <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
              <tabs>
                <Tab text="Transactions (level)">
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <TableView fx:id="transactionsTable" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                 <columns>
                                    <TableColumn text="TransactionId">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="Id" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="TransactionType">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="TransactionType" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Amount">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="Amount" />
                                       </cellValueFactory>
                                    </TableColumn>
                                    <TableColumn text="Date">
                                       <cellValueFactory>
                                          <PropertyValueFactory property="Date" />
