<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.AnchorPane?>

<fx:root prefHeight="690.0" prefWidth="823.0" type="AnchorPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <SplitPane dividerPositions="0.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" orientation="VERTICAL" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
        <AnchorPane maxHeight="40.0" minHeight="40.0" prefHeight="40.0" SplitPane.resizableWithParent="false">
            <ToolBar AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <TextField fx:id="filterTextField" onKeyTyped="#filterTableView" />
                <Button mnemonicParsing="false" onAction="#newPoplavok" text="[ New poplavok ]" />
            <Button mnemonicParsing="false" onAction="#renamePoplavok" text="[ Rename ]" />
                <Button mnemonicParsing="false" onAction="#refreshContent" text="[ Refresh (from DB) ]" />
            <CheckBox fx:id="showClosedCheckBox" mnemonicParsing="false" text="Show closed" />
            </ToolBar>
        </AnchorPane>
        <AnchorPane>
            <TableView fx:id="poplavoksTable" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <columns>
                    <TableColumn text="Id">
                        <cellValueFactory>
                            <PropertyValueFactory property="id" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Account Name">
                        <cellValueFactory>
                            <PropertyValueFactory property="accountName" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Currency">
                        <cellValueFactory>
                            <PropertyValueFactory property="currencyStr" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="AvailableAmount">
                        <cellValueFactory>
                            <PropertyValueFactory property="availableAmountStr" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="ReservedAmount">
                        <cellValueFactory>
                            <PropertyValueFactory property="reservedAmountStr" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="CreationDate">
                        <cellValueFactory>
                            <PropertyValueFactory property="creationDate" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Is Archived?">
                        <cellValueFactory>
                            <PropertyValueFactory property="archivedStatus" />
                        </cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </AnchorPane>
    </SplitPane>
</fx:root>
