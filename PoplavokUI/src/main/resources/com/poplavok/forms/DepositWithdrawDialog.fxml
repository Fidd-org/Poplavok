    <AnchorPane prefHeight="35.0" prefWidth="242.0" VBox.vgrow="NEVER">
        <Button fx:id="depositWithdrawButton" layoutX="97.0" layoutY="1.0" mnemonicParsing="false" onAction="#okClose" text="Deposit/Withdraw" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="97.0" AnchorPane.rightAnchor="97.0" AnchorPane.topAnchor="0.0" />
    </AnchorPane>
