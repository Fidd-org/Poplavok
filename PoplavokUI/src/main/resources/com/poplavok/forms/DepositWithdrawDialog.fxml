        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Amount:" />
            <TextField fx:id="amountTextField" GridPane.columnIndex="1">
