      </GridPane>
    </AnchorPane>
    <AnchorPane VBox.vgrow="ALWAYS">
      <children>
         <TextArea fx:id="detailsTextArea" layoutX="175.0" layoutY="93.0" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0" />
      </children>
