<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<fx:root type="VBox" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <AnchorPane prefHeight="325.0" prefWidth="436.0" VBox.vgrow="NEVER">
      <GridPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="0.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" />
          <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Poplavok:" GridPane.rowIndex="1">
               <GridPane.margin>
                  <Insets right="10.0" />
               </GridPane.margin></Label>
            <ToolBar GridPane.columnIndex="1" GridPane.rowIndex="2">
               <items>
                  <RadioButton fx:id="createNewRadioButton" mnemonicParsing="false" text="Create New">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                     <toggleGroup>
                        <ToggleGroup fx:id="poplavok" />
                     </toggleGroup>
                  </RadioButton>
                  <TextField fx:id="newPoplavokNameTextField" disable="true" editable="false">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </TextField>
               </items>
            </ToolBar>
            <Label text="Fee:" GridPane.rowIndex="3" />
            <ToolBar fx:id="availableToolBar" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <items>
                  <RadioButton fx:id="useExistingRadioButton" mnemonicParsing="false" selected="true" text="Use Existing:" toggleGroup="$poplavok" />
                  <ComboBox fx:id="existingPoplavokComboBox" prefWidth="150.0" />
               </items>
            </ToolBar>
            <ToolBar GridPane.columnIndex="1" GridPane.rowIndex="3">
               <items>
                  <TextField fx:id="feeTextField" prefHeight="26.0" prefWidth="200.0" />
                  <Label fx:id="feeCurrencyLabel" text="CURRENCY" />
               </items>
            </ToolBar>
            <Label text="Price:" GridPane.rowIndex="4" />
            <ToolBar prefHeight="40.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
               <items>
                  <TextField fx:id="priceTextField" prefHeight="26.0" prefWidth="200.0" />
                  <Label fx:id="priceTickerLabel" text="TICKER" />
               </items>
            </ToolBar>
            <Label text="Direction:" />
            <Label fx:id="directionLabel" text="LONG/SHORT" GridPane.columnIndex="1">
               <GridPane.margin>
                  <Insets left="10.0" />
               </GridPane.margin>
            </Label>
            <Label text="Amount:" GridPane.rowIndex="6" />
            <Label text="Proceeds:" GridPane.rowIndex="7" />
            <ToolBar prefHeight="40.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="6">
               <items>
                  <TextField fx:id="amountTextField" prefHeight="26.0" prefWidth="200.0" />
                  <Label fx:id="amountCurrencyLabel" text="CURRENCY" />
               </items>
            </ToolBar>
            <ToolBar prefHeight="40.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="7">
               <items>
                  <TextField fx:id="proceedsTextField" prefHeight="26.0" prefWidth="200.0" />
                  <Label fx:id="proceedsCurrencyLabel" text="CURRENCY" />
               </items>
            </ToolBar>
            <Button mnemonicParsing="false" onAction="#okClose" text="Create Inverse Level" GridPane.columnIndex="1" GridPane.rowIndex="8">
               <GridPane.margin>
                  <Insets left="30.0" />
               </GridPane.margin>
            </Button>
            <Label text="Available:" GridPane.rowIndex="5" />
            <ToolBar prefHeight="40.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="5">
               <items>
                  <TextField fx:id="availableTextField" prefHeight="26.0" prefWidth="200.0" />
                  <Button fx:id="availableCurrencyButton" mnemonicParsing="false" onAction="#addAllAvailable" text="CURRENCY" />
               </items>
            </ToolBar>
         </children>
         <padding>
            <Insets top="10.0" />
         </padding>
      </GridPane>
    </AnchorPane>
</fx:root>
