<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        '-//Hibernate/Hibernate Configuration DTD 3.0//EN'
        'http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd'>
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:file:./poplavok_db;AUTO_SERVER=TRUE</property>
        <property name="hibernate.connection.username">sa</property>

        <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hibernate.hbm2ddl.auto">update</property>
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <property name="connection.pool_size">10</property>
        <property name="current_session_context_class">thread</property>

        <mapping class="com.poplavok.data.model.Currency"/>
        <mapping class="com.poplavok.data.model.CurrencyExtendedInfo"/>
        <mapping class="com.poplavok.data.model.CurrencyChain"/>
        <mapping class="com.poplavok.data.model.Chain"/>
        <mapping class="com.poplavok.data.model.MarketTicker"/>
        <mapping class="com.poplavok.data.model.Rate"/>
        <mapping class="com.poplavok.data.model.Account"/>
        <mapping class="com.poplavok.data.model.Poplavok"/>
        <mapping class="com.poplavok.data.model.Level"/>
        <mapping class="com.poplavok.data.model.LevelTrade"/>
        <mapping class="com.poplavok.data.model.Trade"/>
        <mapping class="com.poplavok.data.model.Transaction"/>
        <mapping class="com.poplavok.data.model.ExternalTransaction"/>
        <mapping class="com.poplavok.data.model.Loan"/>
        <mapping class="com.poplavok.data.model.Repayment"/>
        <mapping class="com.poplavok.data.model.ExternalLoan"/>
        <mapping class="com.poplavok.data.model.VirtualTrade"/>
        <mapping class="com.poplavok.data.model.LoanTransfer"/>
    </session-factory>
</hibernate-configuration>

